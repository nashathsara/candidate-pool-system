{
  "name": "candidate-pool-system",
  "version": "1.0.0",
  "description": "A smart, scalable candidate management system built with React, Firebase, and AI-powered features for modern recruitment workflows.",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm --prefix functions run dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix functions run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nashathsara/candidate-pool-system.git"
  },
  "keywords": [],
